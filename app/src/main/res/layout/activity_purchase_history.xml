<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- TextView for when no history is available -->
    <TextView
        android:id="@+id/noHistoryTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Purchase History Available"
        android:visibility="gone"
        android:gravity="center"
        android:layout_margin="16dp"
        android:textColor="@color/gray_700"
        android:textSize="16sp" />

    <!-- RecyclerView for displaying purchase history -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/purchaseHistoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- BottomNavigationView -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/gray_700"
        app:itemTextColor="@color/gray_700" />

</LinearLayout>
