<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- Splash Activity -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authentication Activities -->
        <activity
            android:name=".SignUpActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.SignUp"
            android:label="@string/signup_activity_label" />
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Login"
            android:label="@string/login_activity_label" />

        <!-- Main App Navigation -->
        <activity
            android:name=".HomePage"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Home"
            android:label="@string/home_activity_label" />
        <activity
            android:name=".SearchPage"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Search"
            android:label="@string/search_activity_label" />
        <activity
            android:name=".CategoryProductsActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.CategoryProducts"
            android:label="@string/category_products_activity_label" />
        <activity
            android:name=".ItemInfoActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.ItemInfo"
            android:label="@string/item_info_activity_label" />
        <activity
            android:name=".CartActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Cart"
            android:label="@string/cart_activity_label" />
        <activity
            android:name=".CheckoutActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Checkout"
            android:label="@string/checkout_activity_label" />
        <activity
            android:name=".OrderConfirmationActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.OrderConfirmation"
            android:label="@string/order_confirmation_activity_label" />

        <!-- User Profile -->
        <activity
            android:name=".ProfileActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.Profile"
            android:label="@string/profile_activity_label" />

        <!-- Purchase History -->
        <activity
            android:name=".PurchaseHistoryActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication.PurchaseHistory"
            android:label="@string/purchase_history_activity_label" />
    </application>
</manifest>
